{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile",
            "type": "shell",
            "command": "mvn",
            "args": ["clean", "compile"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$msCompile"]
        },
        {
            "label": "Run Application",
            "type": "shell",
            "command": "mvn",
            "args": ["javafx:run"],
            "group": {
                "kind": "test"
            },
            "problemMatcher": []
        },
        {
            "label": "Package",
            "type": "shell",
            "command": "mvn",
            "args": ["clean", "package"],
            "group": {
                "kind": "build"
            },
            "problemMatcher": []
        }
    ]
}
